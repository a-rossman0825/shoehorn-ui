{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Lint Current File",
      "type": "shell",
      "command": "npx",
      "args": ["eslint", "${file}"],
      "problemMatcher": ["$eslint-stylish"],
      "group": "test"
    },
    {
      "label": "Lint Current File (Fix)",
      "type": "shell",
      "command": "npx",
      "args": ["eslint", "${file}", "--fix"],
      "problemMatcher": ["$eslint-stylish"],
      "group": "test"
    },
    {
      "label": "Format Current File",
      "type": "shell",
      "command": "npx",
      "args": ["prettier", "${file}", "--write"],
      "group": "build"
    }
  ]
}
